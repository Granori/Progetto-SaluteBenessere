# Rimuovere il .esempio dal nome di questo file
# Modificare eventualmente il valore delle variabili

# Server Config
PORT=3000
NODE_ENV=development # tenere 'development' durante lo sviluppo e 'production' una volta ultimato il progetto

# JWT
JWT_SECRET=chiave_segreta # chiave segreta utilizzata per la firma digitale del token jwt
JWT_DURATA=1h # durata validità del token jwt

# Database
CONNECTION_STRING=connection_string # connection string del database